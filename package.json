{
  "name": "wifi-audio-projector",
  "private": true,
  "version": "1.0.1",
  "workspaces": [
    "project/apps/*",
    "project/packages/*"
  ],
  "scripts": {
    "build": "npm run build:protocol && npm run build:host",
    "build:host": "npm run build --workspace @wifi-audio-projector/host",
    "build:protocol": "npm run build --workspace @wifi-audio-projector/protocol",
    "start:host": "npm run build && electron project/apps/host/dist/main.js"
  }
}
